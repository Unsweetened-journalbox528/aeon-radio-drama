# aeon-radio-drama — environment variables.
# Copy to .env and edit. Read by all four scripts/ via os.environ.

# === ComfyUI server ===
COMFYUI_URL=http://127.0.0.1:8188

# === ComfyUI installation root (for model file lookups + canonical output layout) ===
# If unset, output/ falls back to <repo>/output/
# COMFYUI_ROOT=/path/to/your/ComfyUI

# === Output directory override ===
# OUTPUT_DIR=./output

# === Binary paths (rely on PATH if unset) ===
# FFMPEG=/usr/bin/ffmpeg
# FFPROBE=/usr/bin/ffprobe

# === ACE Step variant default (when scripts don't specify --variant) ===
# ACE_DEFAULT_VARIANT=xl_base

# === HuggingFace token for gated models (Qwen3-TTS, MMAudio sometimes need it) ===
# HF_TOKEN=
